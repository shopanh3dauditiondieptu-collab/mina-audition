# Firebase Admin SDK dùng cho /api/go/[slug]
# Dán toàn bộ JSON service account hoặc chuỗi JSON đã mã hóa Base64.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Các biến CMS/Wiki hiện có của Mina Audition
MINA_ADMIN_USERNAME=
MINA_ADMIN_PASSWORD=
MINA_ADMIN_API_KEY=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_TOKEN=

# Cloudinary, dùng khi Wiki upload ảnh
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
