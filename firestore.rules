rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{id} {
      allow read: if resource.data.status != 'draft';
      allow write: if request.auth != null;
    }
    match /wikiSkills/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
