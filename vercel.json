{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/wiki", "destination": "/wiki.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/api/wiki-skills", "destination": "/database/master-skills.json" },
    { "source": "/sitemap-dynamic.xml", "destination": "/api/seo-sitemap" },
    { "source": "/feed-dynamic.json", "destination": "/api/seo-feed" }
  ],
  "headers": [
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/database/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(post|wiki)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(sitemap.*\\.xml|rss\\.xml|feed.*\\.json|robots\\.txt)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, s-maxage=3600" }]
    },
    {
      "source": "/admin(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex, nofollow" }]
    }
  ]
}
