{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo-sitemap"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/seo-feed"
    }
  ],
  "headers": [
    {
      "source": "/(sitemap.xml|feed.xml|robots.txt)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    },
    {
      "source": "/admin(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}